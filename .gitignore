# Build output (regenerated by start.sh)
frontend/dist/
*.tsbuildinfo

# Playwright (e2e/screenshots/*.png are regenerated by each run, not evidence to track)
frontend/test-results/
frontend/playwright-report/
frontend/e2e/screenshots/

# OS
.DS_Store
