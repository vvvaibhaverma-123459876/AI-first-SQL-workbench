APP_NAME=AI SQL Studio API
DEBUG=true
API_PREFIX=/api

# Local SQLite demo files. Leave blank to use absolute backend/data defaults.
# ANALYTICS_DB_URL=sqlite:////absolute/path/to/backend/data/demo_analytics.db
# METADATA_DB_URL=sqlite:////absolute/path/to/backend/data/app_metadata.db

# v2 control plane: users, workspaces, memberships, audit log. Defaults to a
# local aiosqlite file so a fresh clone still boots with no setup; docker
# compose (and any real multi-user deployment) sets this to Postgres instead —
# SQLite does not hold up under concurrent multi-user writes.
# CONTROL_PLANE_DB_URL=postgresql+asyncpg://sqlstudio:sqlstudio@localhost:5432/sqlstudio
REDIS_URL=redis://localhost:6379/0

# Change this for any deployment beyond your own laptop — it signs every
# session token. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=insecure-dev-secret-change-me

# Local-only AI. No hosted provider key required.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_EXPLAIN_MODEL=llama3.1:8b

DEFAULT_ROW_LIMIT=200
DEFAULT_SQL_LIMIT=200
ASSISTANT_CACHE_ENABLED=true
ASSISTANT_CACHE_MIN_SCORE=0.74
RESULT_CACHE_TTL_SECONDS=900
SQL_EXECUTION_TIMEOUT_SECONDS=30
MAX_REPAIR_ATTEMPTS=2
