APP_NAME=AI SQL Studio API
DEBUG=true
API_PREFIX=/api

# Local SQLite demo files. Leave blank to use absolute backend/data defaults.
# ANALYTICS_DB_URL=sqlite:////absolute/path/to/backend/data/demo_analytics.db
# METADATA_DB_URL=sqlite:////absolute/path/to/backend/data/app_metadata.db

# Local-only AI. No hosted provider key required.
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# OLLAMA_EXPLAIN_MODEL=llama3.1:8b

DEFAULT_ROW_LIMIT=200
DEFAULT_SQL_LIMIT=200
ASSISTANT_CACHE_ENABLED=true
ASSISTANT_CACHE_MIN_SCORE=0.74
RESULT_CACHE_TTL_SECONDS=900
SQL_EXECUTION_TIMEOUT_SECONDS=30
MAX_REPAIR_ATTEMPTS=2
