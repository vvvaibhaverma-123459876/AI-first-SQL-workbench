{
  "name": "ai-first-sql-workbench",
  "private": true,
  "version": "1.1.0-local-ai",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "cd frontend && npm install && cd ../backend && python -m pip install -r requirements.txt",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "test": "cd backend && pytest && cd ../frontend && npm run test -- --run"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
